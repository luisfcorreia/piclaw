{
  "id": "js-yaml",
  "packageName": "js-yaml",
  "sourceEntry": "web/src/vendor/js-yaml-entry.ts",
  "outputFile": "web/static/js/vendor/js-yaml.min.js",
  "metadataFile": "web/static/js/vendor/js-yaml.meta.json",
  "buildCommand": [
    "bun",
    "build",
    "$SOURCE_ENTRY",
    "--target=browser",
    "--format=iife",
    "--minify",
    "--outfile",
    "$OUTPUT_FILE"
  ]
}
