{
  "id": "d3-mindmap",
  "packageName": "d3",
  "sourceEntry": "web/src/vendor/d3-mindmap-entry.ts",
  "outputFile": "web/static/js/vendor/d3-mindmap.min.js",
  "metadataFile": "web/static/js/vendor/d3-mindmap.meta.json",
  "buildCommand": [
    "bun",
    "build",
    "$SOURCE_ENTRY",
    "--target=browser",
    "--format=iife",
    "--minify",
    "--outfile",
    "$OUTPUT_FILE"
  ]
}
