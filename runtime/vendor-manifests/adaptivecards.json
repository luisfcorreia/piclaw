{
  "id": "adaptivecards",
  "packageName": "adaptivecards",
  "sourceEntry": "web/src/vendor/adaptivecards-entry.ts",
  "outputFile": "web/static/js/vendor/adaptivecards.min.js",
  "metadataFile": "web/static/js/vendor/adaptivecards.meta.json",
  "buildCommand": [
    "bun",
    "build",
    "$SOURCE_ENTRY",
    "--target=browser",
    "--format=iife",
    "--minify",
    "--outfile",
    "$OUTPUT_FILE"
  ]
}
